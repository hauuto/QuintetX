# QuintetX environment example
# Copy this file to `.env` and edit values as needed.

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Database
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=quintetx

# App
DEBUG=true
APP_ENV=dev
AUTO_SEED_ON_STARTUP=true

# Game
# Delay mỗi step/poll (giây) — nên đặt 0.5 đến 1.0
TIME_PER_MOVE=0.75
# Thời gian tối đa mỗi lượt (giây)
MOVE_TIMEOUT_SECONDS=10

# Security
# IMPORTANT: change this in real deployments
SECRET_KEY=change_this_to_a_secure_random_string
